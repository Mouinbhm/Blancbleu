{
  "name": "blancbleu-server",
  "version": "1.3.0",
  "description": "Backend API - Plateforme BlancBleu",
  "main": "Server.js",
  "scripts": {
    "start": "node Server.js",
    "dev": "nodemon Server.js",
    "create-admin": "node scripts/create-admin.js",
    "seed": "node seed.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest --testPathPattern=__tests__/unit --runInBand --forceExit",
    "test:integration": "jest --testPathPattern=__tests__/integration --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\"",
    "docs:openapi": "node scripts/dump-openapi.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "setupFilesAfterEnv": [
      "./jest.setup.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/_deprecated/"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "controllers/gdprController.js",
      "middleware/auth.js",
      "middleware/auditMiddleware.js",
      "middleware/httpLogger.js",
      "middleware/rateLimiter.js",
      "middleware/sanitize.js",
      "middleware/validate.js",
      "services/transportStateMachine.js",
      "services/tarifService.js",
      "services/predictionService.js",
      "utils/geoUtils.js",
      "utils/healthCheck.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 60,
        "branches": 50,
        "functions": 60,
        "lines": 60
      },
      "./services/transportStateMachine.js": {
        "branches": 75,
        "functions": 90,
        "lines": 85
      },
      "./middleware/auth.js": {
        "branches": 80,
        "functions": 100,
        "lines": 85
      },
      "./middleware/auditMiddleware.js": {
        "lines": 75
      },
      "./utils/geoUtils.js": {
        "functions": 60,
        "lines": 65
      }
    }
  },
  "dependencies": {
    "@bull-board/api": "^7.1.5",
    "@bull-board/express": "^7.1.5",
    "@sentry/node": "^10.53.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "blancbleu-monorepo": "file:..",
    "bullmq": "^5.77.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.0",
    "firebase-admin": "^13.10.0",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^2.1.1",
    "nanoid": "^3.3.12",
    "nodemailer": "^8.0.4",
    "pdfkit": "^0.18.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^5.0.0",
    "socket.io": "^4.6.2",
    "speakeasy": "^2.0.0",
    "stripe": "^22.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "web-push": "^3.6.7",
    "winston": "^3.19.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^29.7.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-promise": "^7.3.0",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.4.1",
    "nodemon": "^3.0.2",
    "prettier": "^3.8.3",
    "supertest": "^7.0.0"
  }
}
