# ══════════════════════════════════════════════════════════════════════════════
# BlancBleu — Variables d'environnement v1.3
# Copier : cp .env.example .env
# Ne jamais committer le .env réel
# ══════════════════════════════════════════════════════════════════════════════

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/blancbleu
MONGO_USER=blancbleu
# Générer un mot de passe fort : openssl rand -base64 32
MONGO_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Générer : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_A_STRONG_64_CHAR_SECRET

# ─── Serveur ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Logging ──────────────────────────────────────────────────────────────────
# Niveaux : error | warn | info | debug
LOG_LEVEL=info

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ─── Module IA FastAPI ────────────────────────────────────────────────────────
AI_API_URL=http://localhost:5002

# ─── Token partagé Node ↔ Python (service-to-service) ────────────────────────
# Utilisé par les endpoints GET /api/ai/training-data, POST /optimizer/model/retrain.
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DOIT être identique côté server (Node) et ia (Python).
AI_SERVICE_TOKEN=CHANGE_ME_64_CHAR_HEX

# URL du backend Node vue depuis le microservice IA Python (pour le pull
# du dataset). En local hors Docker : http://localhost:5000.
# En Docker : http://server:5000.
NODE_API_URL=http://localhost:5000

# ─── Redis (cache + rate limiter distribué + BullMQ workers) ─────────────────
# OPTIONNEL. Si laissé vide, le cache analytics + le rate limiter retombent en
# mémoire et BullMQ devient un no-op (jobs async non traités). Recommandé en
# production multi-instance. En local : docker run --rm -p 6379:6379 redis:7-alpine
# REDIS_DISABLED=true permet aussi de forcer l'OFF (override REDIS_URL).
REDIS_URL=redis://localhost:6379

# ─── OSRM Routing (Phase 3) ───────────────────────────────────────────────────
# Instance publique (dev) — auto-héberger en production
# https://github.com/Project-OSRM/osrm-backend
OSRM_URL=https://router.project-osrm.org

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre-email@gmail.com
EMAIL_PASS=votre-app-password-gmail
EMAIL_FROM=BlancBleu <noreply@blancbleu.fr>

# ─── Notifications superviseurs (Phase 3) ────────────────────────────────────
# Emails séparés par virgule — reçoivent les alertes P1, NOVI, carburant
SUPERVISEUR_EMAILS=superviseur@blancbleu.fr,admin@blancbleu.fr

# ─── Stripe (backend) ─────────────────────────────────────────────────────────
# Clé SECRÈTE côté serveur uniquement — ne jamais exposer côté client
# Obtenir depuis : https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REMPLACER_PAR_VOTRE_CLE_SECRETE

# ─── Métriques Prometheus ─────────────────────────────────────────────────────
# Token requis pour accéder à GET /metrics. Sans valeur, l'endpoint refuse.
# Générer : node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
METRICS_TOKEN=

# ─── Antivirus ClamAV (scan des uploads) ─────────────────────────────────────
# Active le scan antivirus des fichiers uploadés (PMT, documents, avatars).
# Par défaut : activé en production, désactivé sinon (dev/test sans démon).
CLAMAV_ENABLED=true
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
# fail-open : si le démon ClamAV est injoignable, true = laisser passer (avec
# log d'alerte), false = bloquer l'upload (fail-closed, recommandé en prod).
CLAMAV_FAIL_OPEN=false

# ─── Protection CSRF ──────────────────────────────────────────────────────────
# Active la protection CSRF (double-submit cookie) sur les routes mutantes.
# Désactivable (false) pour débloquer les tests E2E si besoin.
CSRF_ENABLED=true

# ─── Observabilité (Sentry) — OPTIONNEL ──────────────────────────────────────
# Sans DSN, Sentry est désactivé silencieusement (init est un no-op).
# Backend (server + worker) :
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# Frontend (React, lu au build via CRA — process.env.REACT_APP_*) :
REACT_APP_SENTRY_DSN=
REACT_APP_SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Premier admin ────────────────────────────────────────────────────────────
# Retirer après : npm run create-admin
ADMIN_EMAIL=admin@blancbleu.fr
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ADMIN_NOM=Admin
ADMIN_PRENOM=BlancBleu

# ─── Chiffrement champs sensibles (AES-256-GCM) ───────────────────────────
# Utilisé pour Patient.numeroSecu et autres champs PII
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=CHANGE_ME_32_BYTES_BASE64

# ─── Web Push (VAPID) — Sprint 6 Module D ────────────────────────────────────
# Générer la paire de clés : node server/scripts/generate-vapid.js
# Sans ces variables, le service Web Push est désactivé silencieusement
# (l'endpoint /api/notifications/push/vapid-public-key retournera 503,
#  et tous les sendPushTo* deviennent no-op).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@blancbleu.fr

# ─── Firebase Cloud Messaging (FCM) — Sprint M4 ──────────────────────────────
# Service account JSON pour envoyer des push aux apps mobiles (driver + patient).
# Sans cette variable, FCM est désactivé silencieusement (toutes les fonctions
# push deviennent no-op, l'app tourne en mode socket + notifs locales).
#
# 3 formats acceptés (le service détecte automatiquement) :
#   1. JSON inline       (commence par `{`)
#   2. JSON encodé base64 (utile pour les env longues — Docker/CI)
#   3. Chemin de fichier (ex: `./firebase-service-account.json`)
#
# Procédure : Firebase Console > Project Settings > Service accounts >
# "Generate new private key" → télécharger le JSON → poser dans server/
# (gitignored) OU coller le contenu base64 ci-dessous.
# Doc complète : docs/push-notifications.md
FIREBASE_SERVICE_ACCOUNT=